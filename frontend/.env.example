# Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# Application
VITE_APP_NAME=ReferAI
VITE_APP_VERSION=1.0.0
VITE_DEBUG=true

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Feature Flags
VITE_FEATURE_MOCK_INTERVIEWS=true
VITE_FEATURE_RESUME_ANALYZER=true
VITE_FEATURE_REFERRALS=true
VITE_FEATURE_LEARNING_HUB=true
VITE_FEATURE_GAMIFICATION=true
