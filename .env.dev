# ReferAI Development Environment Configuration
# This is the local development .env file

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_PORT=5432
DB_NAME=referai_dev
DB_USER=referai_user
DB_PASSWORD=dev_password

# REDIS CONFIGURATION
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT CONFIGURATION
JWT_SECRET=dev_secret_key_12345678901234567890123456789
JWT_EXPIRY=86400
JWT_REFRESH_EXPIRY=604800

# OAUTH CONFIGURATION (Get from your dev apps)
GOOGLE_CLIENT_ID=dev_google_client_id
GOOGLE_CLIENT_SECRET=dev_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=dev_github_client_id
GITHUB_CLIENT_SECRET=dev_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# AI SERVICES CONFIGURATION
OPENAI_API_KEY=sk_dev_key
OPENAI_MODEL=gpt-4

GEMINI_API_KEY=dev_gemini_key
GEMINI_MODEL=gemini-pro

# FILE UPLOAD CONFIGURATION
FILE_UPLOAD_DIR=/d/ReferAI/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx

# EMAIL CONFIGURATION
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=dev
MAIL_PASSWORD=dev
MAIL_FROM=dev@referai.com

# APPLICATION CONFIGURATION
ENVIRONMENT=dev
APP_NAME=ReferAI
APP_VERSION=1.0.0
APP_URL=http://localhost
APP_DEBUG=true

# FRONTEND CONFIGURATION
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080
REACT_APP_APP_NAME=ReferAI Dev

# LOGGING CONFIGURATION
LOG_LEVEL=DEBUG
LOG_FILE=/d/ReferAI/logs/app.log

# PAYMENT CONFIGURATION
STRIPE_PUBLIC_KEY=pk_test_dev
STRIPE_SECRET_KEY=sk_test_dev

# SECURITY CONFIGURATION
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# DATABASE BACKUP
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
