# ReferAI Environment Configuration

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=referai
DB_USER=referai_user
DB_PASSWORD=dev_password

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# JWT CONFIGURATION
# ============================================================================

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=86400
JWT_REFRESH_EXPIRY=604800

# ============================================================================
# OAUTH CONFIGURATION
# ============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ============================================================================
# AI SERVICES CONFIGURATION
# ============================================================================

# OpenAI API
OPENAI_API_KEY=sk_test_your_openai_api_key
OPENAI_MODEL=gpt-4

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

FILE_UPLOAD_DIR=/d/ReferAI/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@referai.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=dev
# Options: dev, test, prod

# Application
APP_NAME=ReferAI
APP_VERSION=1.0.0
APP_URL=http://localhost
APP_DEBUG=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080
REACT_APP_APP_NAME=ReferAI

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=/d/ReferAI/logs/app.log

# ============================================================================
# PAYMENT CONFIGURATION (For Phase Future)
# ============================================================================

STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ============================================================================
# DATABASE BACKUP
# ============================================================================

BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
